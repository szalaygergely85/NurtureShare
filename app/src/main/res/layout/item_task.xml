<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_task"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="2dp"
    app:rippleColor="@color/primary_fixed"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <!-- Checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_complete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="12dp"
            app:buttonTint="@color/primary"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title row: title | nudge button | assignment badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/quicksand"
                    android:maxLines="2"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Nudge button — circular, secondary tint, next to badge (matches HTML design) -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_nudge"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_nudge_circle"
                    android:contentDescription="Nudge partner"
                    android:padding="6dp"
                    android:src="@drawable/ic_bell"
                    android:tint="@color/secondary"
                    android:visibility="gone"/>

                <!-- Assignment pill badge -->
                <LinearLayout
                    android:id="@+id/ll_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_badge_pill">

                    <ImageView
                        android:id="@+id/iv_badge_icon"
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:layout_marginEnd="3dp"/>

                    <TextView
                        android:id="@+id/tv_badge_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.05"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Meta row -->
            <LinearLayout
                android:id="@+id/ll_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Due date -->
                <ImageView
                    android:id="@+id/iv_date_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Due date"
                    android:src="@drawable/ic_calendar"
                    android:visibility="gone"
                    app:tint="@color/on_surface_variant"/>

                <TextView
                    android:id="@+id/tv_due_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <!-- Dot separator (shown when date + sync both visible) -->
                <View
                    android:id="@+id/view_meta_dot"
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_dot"
                    android:visibility="gone"/>

                <!-- Synced indicator -->
                <ImageView
                    android:id="@+id/iv_sync_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Synced"
                    android:src="@drawable/ic_sync"
                    android:visibility="gone"
                    app:tint="@color/primary"/>

                <TextView
                    android:id="@+id/tv_synced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Synced"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"/>

                <!-- Completed label (replaces date/sync when done) -->
                <ImageView
                    android:id="@+id/iv_completed_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Completed"
                    android:src="@drawable/ic_checklist"
                    android:visibility="gone"
                    app:tint="@color/on_surface_variant"/>

                <TextView
                    android:id="@+id/tv_completed_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <!-- Comment count (hidden when 0) -->
                <TextView
                    android:id="@+id/tv_comments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:drawableStart="@drawable/ic_chat"
                    android:drawableTint="@color/on_surface_variant"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical"
                    android:text="0"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
