<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/margin_mobile">

        <!-- ── Top bar: back │ title │ save pill ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Back"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@color/on_surface"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:fontFamily="@font/quicksand"
                android:text="@string/add_note_screen_title"
                android:textColor="@color/on_surface"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_note"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/btn_save"
                android:textColor="@color/on_primary"
                app:cornerRadius="20dp"/>

        </LinearLayout>

        <!-- ── Large title input ── -->
        <EditText
            android:id="@+id/et_note_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@null"
            android:fontFamily="@font/quicksand"
            android:hint="@string/hint_note_title"
            android:inputType="textCapSentences"
            android:maxLines="3"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/outline_variant"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- ── Category chips (no label, matches HTML) ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_ideas"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/notes_tab_ideas"
                    app:chipIcon="@drawable/ic_lightbulb"
                    app:chipIconTint="@color/primary"
                    app:chipIconVisible="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_shopping"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notes_tab_shopping"
                    app:chipIcon="@drawable/ic_shopping_cart"
                    app:chipIconTint="@color/primary"
                    app:chipIconVisible="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_questions"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notes_tab_questions"
                    app:chipIcon="@drawable/ic_help"
                    app:chipIconTint="@color/primary"
                    app:chipIconVisible="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_medical"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notes_tab_medical"
                    app:chipIcon="@drawable/ic_medical"
                    app:chipIconTint="@color/primary"
                    app:chipIconVisible="true"/>

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- ── Note card: toolbar + body + sync indicator ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Toolbar row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:paddingBottom="12dp">

                    <!-- Formatting buttons -->
                    <androidx.appcompat.widget.AppCompatImageButton
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Checklist"
                        android:padding="6dp"
                        android:src="@drawable/ic_checklist"
                        android:tint="@color/on_surface_variant"/>

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Bullet list"
                        android:padding="6dp"
                        android:src="@drawable/ic_format_list"
                        android:tint="@color/on_surface_variant"/>

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Image"
                        android:padding="6dp"
                        android:src="@drawable/ic_image"
                        android:tint="@color/on_surface_variant"/>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@color/outline_variant"/>

                    <!-- Tag Partner pill (visual only — no backend support) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tag_partner_pill"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="4dp"
                            android:src="@drawable/ic_person"
                            android:tint="@color/on_secondary_fixed_variant"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/note_tag_partner"
                            android:textColor="@color/on_secondary_fixed_variant"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.04"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider under toolbar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/surface_container_low"/>

                <!-- Body textarea -->
                <EditText
                    android:id="@+id/et_note_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="@string/hint_note_body"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="8"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/outline_variant"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.4"/>

                <!-- Sync indicator — shown at bottom of card when share switch is on -->
                <LinearLayout
                    android:id="@+id/ll_sync_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    android:paddingTop="12dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <!-- Pulsing dot approximation: small filled circle -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_dot_primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/note_synced_with_partner"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Share with Partner card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/primary_fixed"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Icon in white circle -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_white_circle">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_group"
                        android:tint="@color/primary"
                        android:contentDescription="Partner"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/quicksand"
                        android:text="@string/note_share_with_partner"
                        android:textColor="@color/on_primary_fixed"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/note_share_description"
                        android:textColor="@color/on_primary_fixed_variant"
                        android:textSize="11sp"/>

                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_share_partner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:indeterminate="true"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
